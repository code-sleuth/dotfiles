# General UID/GID and Timezone
TZ=Africa/Nairobi
PUID=501
PGID=20

# Paths: app configs on internal disk, media/downloads on the 980 drive
CONFIG_ROOT=/Users/code/docker/servarr
DATA_ROOT=/Volumes/980/data

# --- VPN (unused — stack currently runs without gluetun) -------------------
