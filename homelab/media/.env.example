SET_IP_SONARR=172.39.0.3
SET_IP_RADARR=172.39.0.4
SET_IP_LIDARR=172.39.0.5
SET_IP_BAZARR=172.39.0.6
SET_IP_SEERR=172.39.0.7
SET_IP_PROWLARR=172.39.0.8
SET_IP_QBITTORRENT=172.39.0.9
SET_IP_NZBGET=172.39.0.10
