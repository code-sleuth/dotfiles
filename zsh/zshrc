# History: interactive search
__history() {
  LBUFFER="$(fc -ln 0 | fzf --query="${LBUFFER}")"
  zle redisplay
}

zle -N __history

# Completion
LISTMAX=10000  # do not show warning if there is too much items in completion

setopt glob_dots  # include dotfiles into completion by default
setopt hash_cmds  # hash command locations
setopt list_packed

zmodload zsh/complist  # required for menu-select navigation (arrows, vim motions)
fpath=($HOME/.docker/completions $fpath)  # Docker CLI completions (moved here so compinit picks them up)
autoload -Uz compinit
compinit -C  # -C disables security checks on dump file

# _complete is base completer
# _approximate will fix completion if there is no matches
# _extensions will complete glob patters with extensions
zstyle ':completion:*' completer _extensions _complete _approximate

zstyle ':completion:*' menu no-select  # fzf-tab renders the picker, so disable zsh's native menu
zstyle ':completion:*' increment yes
zstyle ':completion:*' verbose yes
zstyle ':completion:*' squeeze-slashes yes  # replace // with /

zstyle ':completion:*' file-sort modification  # show recently used files first
zstyle ':completion:*' list-dirs-first yes
# Color: LS_COLORS for files/dirs + nushell-style name/description coloring
# Pattern groups: (name)( -- )(description) â†’ default, dim, yellow
zstyle ':completion:*' list-colors ${(s.:.)LS_COLORS} '=(#b)(*)( -- )(*)=0=2=33'
zstyle ':completion:*' ignored-patterns '.git'

zstyle ':completion:*' rehash false  # improves performance
zstyle ':completion:*' use-cache true

# Carapace: multi-shell completion engine (bridges bash/fish/zsh completions)
export CARAPACE_BRIDGES='zsh,fish,bash,inshellisense'
zstyle ':completion:*:descriptions' format '[%d]'
zstyle ':completion:*:git-checkout:*' sort false
if command -v carapace >/dev/null 2>&1; then
  source <(carapace _carapace zsh)
fi

# fzf-tab: replaces zsh's default completion menu with an fzf picker
# (gives the same arrow/j/k/Tab navigation experience as nushell's completion_menu)
# NOTE: the plugin itself is sourced AFTER `eval "$(fzf --zsh)"` further down,
# because fzf's shell integration rebinds Tab to `fzf-completion` and would clobber us.
zstyle ':fzf-tab:*' use-fzf-default-opts no
zstyle ':fzf-tab:*' fzf-flags \
  '--color=fg:#cbe0f0,bg:-1,hl:#ffcc66,fg+:#011628,bg+:#7dcfff,hl+:#011628,gutter:-1,info:#7dcfff,border:#143652,prompt:#7dcfff,pointer:#7dcfff,marker:#7dcfff' \
  '--no-info' '--no-separator' '--prompt= ' '--pointer= ' '--layout=reverse' '--height=40%'
zstyle ':fzf-tab:*' switch-group '<' '>'
zstyle ':fzf-tab:complete:cd:*' fzf-preview 'eza --color=always --long --git --icons=always $realpath 2>/dev/null || ls -la $realpath'


# Keyboard
unsetopt flow_control  # disable ^S / ^Q

bindkey -e  # Zsh default keybindings are vim, because EDITOR is set to vim, use emacs ones

# Tab uses zsh's default `expand-or-complete`, which fzf-tab wraps to render the fzf picker
bindkey '^[[3~' delete-char  # Delete
bindkey '^[[1;5D' backward-word  # Control-Left
bindkey '^[[1;5C' forward-word  # Control-Right

bindkey '^R' __history

# Line editor
