export NVM_DIR="$HOME/.nvm"
# NVM: lazy init (sourcing nvm.sh + nvm_auto costs ~480ms; defer until needed).
# Add the most recent installed node version to PATH so `node`/`npm` work without sourcing nvm.
if [ -d "$NVM_DIR/versions/node" ]; then
  _nvm_latest_node="$(command ls -t "$NVM_DIR/versions/node" 2>/dev/null | head -1)"
  [ -n "$_nvm_latest_node" ] && export PATH="$NVM_DIR/versions/node/$_nvm_latest_node/bin:$PATH"
  unset _nvm_latest_node
fi
# Wrap nvm-aware commands so the first call sources nvm.sh, then re-runs itself.
_nvm_lazy_load() {
  unset -f nvm node npm npx yarn pnpm corepack 2>/dev/null
  [ -s "/opt/homebrew/opt/nvm/nvm.sh" ] && \. "/opt/homebrew/opt/nvm/nvm.sh"
}
nvm()      { _nvm_lazy_load && nvm "$@"; }
node()     { _nvm_lazy_load && node "$@"; }
npm()      { _nvm_lazy_load && npm "$@"; }
npx()      { _nvm_lazy_load && npx "$@"; }
yarn()     { _nvm_lazy_load && yarn "$@"; }
pnpm()     { _nvm_lazy_load && pnpm "$@"; }
corepack() { _nvm_lazy_load && corepack "$@"; }
